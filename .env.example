# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Groq API (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace Inference API (free at huggingface.co/settings/tokens)
HF_API_TOKEN=your_huggingface_token_here

# Google Sheets (only needed if USE_SHEETS=true)
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# The spreadsheet ID from the sheet URL
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Storage mode: "sheets" or "sqlite"
STORAGE_MODE=sqlite

# Telegram publishing (optional - Phase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Filtering thresholds (tune these after observing results)
IMPORTANCE_SCORE_THRESHOLD=3.0
DEDUP_SIMILARITY_THRESHOLD=0.85
HF_CLASSIFICATION_THRESHOLD=0.55
